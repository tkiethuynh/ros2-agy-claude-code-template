{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(colcon build:*)",
      "Bash(colcon test:*)",
      "Bash(colcon test-result:*)",
      "Bash(colcon list:*)",
      "Bash(colcon graph:*)",
      "Bash(ros2:*)",
      "Bash(rosdep:*)",
      "Bash(vcs:*)",
      "Bash(rviz2:*)",
      "Bash(rqt:*)",
      "Bash(rqt_graph:*)",
      "Bash(rqt_console:*)",
      "Bash(rqt_plot:*)",
      "Bash(rqt_tf_tree:*)",
      "Bash(ament_uncrustify:*)",
      "Bash(ament_cpplint:*)",
      "Bash(ament_flake8:*)",
      "Bash(ament_pep257:*)",
      "Bash(ament_xmllint:*)",
      "Bash(ament_copyright:*)",
      "Bash(pre-commit run:*)",
      "Bash(clang-format:*)",
      "Bash(clang-tidy:*)",
      "Bash(pytest:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(pip install:*)",
      "Bash(python3 -m pip install:*)",
      "Bash(cmake:*)",
      "Bash(make:*)",
      "Bash(ninja:*)",
      "Bash(ctest:*)",
      "Bash(bazel build:*)",
      "Bash(bazel test:*)",
      "Bash(bazel query:*)",
      "Bash(gz sim:*)",
      "Bash(gz topic:*)",
      "Bash(gz model:*)",
      "Bash(gz log:*)",
      "Bash(gz service:*)",
      "Bash(gz param:*)",
      "Bash(cppcheck:*)",
      "Bash(xvfb-run:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(ls:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "WebFetch(domain:docs.ros.org)",
      "WebFetch(domain:navigation.ros.org)",
      "WebFetch(domain:design.ros2.org)",
      "WebFetch(domain:github.com)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(rm -rf build*)",
      "Bash(rm -rf install*)",
      "Bash(rm -rf log*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(docker:*)",
      "Bash(rm -rf /*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(~/.ssh/**)"
    ]
  },
  "env": {
    "ROS_DISTRO": "humble",
    "RMW_IMPLEMENTATION": "rmw_fastrtps_cpp",
    "GZ_VERSION": "harmonic"
  }
}
